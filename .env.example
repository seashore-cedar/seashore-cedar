# Email settings — use Gmail SMTP or any SMTP provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Seashore Cedar <your-gmail@gmail.com>

# The email address that receives order/contact form submissions
CONTACT_FORM_RECIPIENT_EMAIL=your-email@example.com

# Your public domain (used for sitemap)
PUBLIC_URL=https://www.yourdomain.com
